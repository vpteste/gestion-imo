{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build -w packages/shared && npm run build -w apps/web",
  "installCommand": "npm ci --ignore-scripts",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gestion-imo-api.onrender.com/:path*"
    }
  ]
}
