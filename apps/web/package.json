{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "powershell -NoProfile -Command \"if (Test-Path '.next') { Remove-Item '.next' -Recurse -Force }; if (Test-Path '.next-build') { Remove-Item '.next-build' -Recurse -Force }\"",
    "dev:clean": "npm run clean && next dev -p 3000",
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test": "echo \"No tests yet for web\"",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@gestion/shared": "0.1.0",
    "leaflet": "^1.9.4",
    "next": "^14.2.33",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
